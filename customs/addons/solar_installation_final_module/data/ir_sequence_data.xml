<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- Solar Project Sequence -->
        <record id="seq_solar_project" model="ir.sequence">
            <field name="name">Solar Project Sequence</field>
            <field name="code">solar.project</field>
            <field name="prefix">PROJ/</field>
            <field name="padding">5</field>
            <field name="number_next">1</field>
            <field name="number_increment">1</field>
            <field name="company_id" eval="False"/>
        </record>

        <!-- Solar Quote Sequence -->
        <record id="seq_solar_quote" model="ir.sequence">
            <field name="name">Solar Quote Sequence</field>
            <field name="code">solar.quote</field>
            <field name="prefix">QUO/</field>
            <field name="padding">5</field>
            <field name="number_next">1</field>
            <field name="number_increment">1</field>
            <field name="company_id" eval="False"/>
        </record>

        <!-- Solar Site Survey Sequence -->
        <record id="seq_solar_site_survey" model="ir.sequence">
            <field name="name">Solar Site Survey Sequence</field>
            <field name="code">solar.site.survey</field>
            <field name="prefix">SURV/</field>
            <field name="padding">5</field>
            <field name="number_next">1</field>
            <field name="number_increment">1</field>
            <field name="company_id" eval="False"/>
        </record>

        <!-- Solar Installation Schedule Sequence -->
        <record id="seq_solar_install_schedule" model="ir.sequence">
            <field name="name">Solar Installation Schedule Sequence</field>
            <field name="code">solar.install.schedule</field>
            <field name="prefix">SCH/</field>
            <field name="padding">5</field>
            <field name="number_next">1</field>
            <field name="number_increment">1</field>
            <field name="company_id" eval="False"/>
        </record>

    </data>
</odoo>
