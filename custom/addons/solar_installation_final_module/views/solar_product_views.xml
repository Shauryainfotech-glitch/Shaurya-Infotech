<odoo>
    <data>
        <!-- Action for Solar Projects -->
            <record id="action_solar_product_views" model="ir.actions.act_window">
            <field name="name">Solar Products</field>
            <field name="res_model">solar.product.product</field>
            <field name="view_mode">form</field> <!-- Only form view -->
            <field name="target">current</field>
        </record>

  <record id="view_solar_product_form" model="ir.ui.view">
            <field name="name">solar.product.form</field>
            <field name="model">product.template</field>
            <field name="arch" type="xml">
                <form string="Product Information">
                    <sheet>
                        <group>
                            <!-- Only the product-related fields are included -->
                            <field name="name" string="Product Name" required="1"/>
                            <field name="product_category_id" string="Product Category" required="1"/>
                            <field name="default_code" string="Internal Product Code"/>
                            <field name="brand_id" string="Brand/Manufacturer"/>
                            <field name="description" string="Description"/>
                        </group>

                        <group>
                            <!-- Technical Specifications -->
                            <field name="capacity" string="Capacity (Watt)" widget="float" digits="(12, 2)"/>
                            <field name="voltage" string="Voltage (V)" widget="float" digits="(12, 2)"/>
                            <field name="current" string="Current (A)" widget="float" digits="(12, 2)"/>
                            <field name="efficiency" string="Efficiency (%)" widget="float" digits="(5, 2)"/>
                            <field name="weight" string="Weight (kg)" widget="float" digits="(6, 2)"/>
                            <field name="width" string="Width (mm)" widget="float" digits="(6, 2)"/>
                            <field name="height" string="Height (mm)" widget="float" digits="(6, 2)"/>
                        </group>

                        <group>
                            <!-- Price Information -->
                            <field name="list_price" string="List Price" widget="monetary" currency_field="currency_id"/>
                            <field name="cost_price" string="Cost Price" widget="monetary" currency_field="currency_id"/>
                            <field name="currency_id" string="Currency" options="{'no_create': True}"/>
                        </group>

                        <group>
                            <!-- Barcode, UOM, and Stock -->
                            <field name="barcode" string="Barcode"/>
                            <field name="uom_id" string="Unit of Measure"/>
                            <field name="stock_quantity" string="Quantity On Hand"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>
    </data>
</odoo>
