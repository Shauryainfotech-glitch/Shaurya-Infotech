<odoo>
    <data>
        <!-- Action for Solar Products -->
        <record id="action_solar_product_views" model="ir.actions.act_window">
            <field name="name">Solar Products</field>
            <field name="res_model">solar.product.product</field>
            <field name="view_mode">form</field> <!-- Only form view -->
            <field name="target">current</field>
        </record>

        <!-- Form View for Solar Projects -->
        <record id="view_solar_project_form" model="ir.ui.view">
            <field name="name">solar.project.form</field>
            <field name="model">solar.project</field>
            <field name="arch" type="xml">
                <form string="Solar Project">
                    <header>
                        <field name="state" widget="statusbar"
                               statusbar_visible="draft,surveyed,quoted,confirmed,scheduled,in_progress,completed,cancelled"/>
                    </header>
                    <sheet>
                        <!-- Group only product-related fields -->
                        <group>
                            <field name="name" readonly="1"/>
                            <field name="project_name"/>
                            <field name="customer_id" options="{'no_create': True}"/>
                            <field name="inquiry_date" readonly="1"/>
                        </group>

                        <!-- Notebook for Products tab -->
                        <notebook>
                            <!-- Products (BOM) Tab -->
                            <page string="Products (BOM)">
                                <field name="product_line_ids">
                                    <form>
                                        <field name="product_id"/>
                                        <field name="quantity"/>
                                        <field name="unit_cost"/>
                                        <field name="manual_unit_cost"/>
                                        <field name="subtotal"/>
                                    </form>
                                </field>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>
    </data>
</odoo>
