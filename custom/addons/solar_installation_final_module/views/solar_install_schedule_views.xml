<?xml version="1.0" encoding="utf-8"?>
<odoo>
   <data>
  <!-- Action for Installation Schedules -->
  <record id="action_solar_install_schedule" model="ir.actions.act_window">
    <field name="name">Installation Schedules</field>
    <field name="res_model">solar.install.schedule</field>
    <field name="view_mode">form</field>
    <field name="help" type="html">
      <p class="o_view_nocontent_smiling_face">
        Create your first installation schedule
      </p>
    </field>
  </record>

  <!-- Form View -->
  <record id="view_solar_install_schedule_form" model="ir.ui.view">
    <field name="name">solar.install.schedule.form</field>
    <field name="model">solar.install.schedule</field>
    <field name="arch" type="xml">
      <form string="Installation Schedule" version="1.1">
        <header>
          <!-- Statusbar for states -->
          <field name="state" widget="statusbar" statusbar_visible="planned,in_progress,done,cancelled"/>

          <!-- Start Button (visible only in 'planned' state) -->
          <button string="Start" type="object" name="action_start"
                  modifiers="{'invisible': [('state', '!=', 'planned')]}"/>

          <!-- Done Button (visible only in 'in_progress' state) -->
          <button string="Done" type="object" name="action_done"
                  modifiers="{'invisible': [('state', '!=', 'in_progress')]}"/>

          <!-- Cancel Button (visible in 'planned' and 'in_progress' states) -->
          <button string="Cancel" type="object" name="action_cancel"
                  modifiers="{'invisible': [('state', 'not in', ['planned', 'in_progress'])]}"/>
        </header>

        <sheet>
          <group>
            <field name="project_id"/>
            <field name="team_id"/>
            <field name="scheduled_by" readonly="1"/>
          </group>
          <group>
            <field name="start_datetime"/>
            <field name="duration_hours"/>
            <field name="end_datetime" readonly="1"/>
          </group>
          <group>
            <field name="assigned_employee_ids" widget="many2many_tags"/>
            <field name="state"/>
          </group>
          <group>
            <field name="notes"/>
          </group>
        </sheet>
      </form>
    </field>
  </record>
   </data>
</odoo>
