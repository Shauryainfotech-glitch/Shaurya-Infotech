<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Action for Solar Quotes -->
        <record id="action_solar_quote" model="ir.actions.act_window">
            <field name="name">Solar Quotes</field>
            <field name="res_model">solar.quote</field>
            <field name="view_mode">form</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Create your first solar quote
                </p>
            </field>
        </record>

        <!-- Form View for Solar Quotes -->
        <record id="view_solar_quote_form" model="ir.ui.view">
            <field name="name">solar.quote.form</field>
            <field name="model">solar.quote</field>
            <field name="arch" type="xml">
                <form string="Solar Quote">
                    <header>
                        <field name="state" widget="statusbar" statusbar_visible="draft,quoted,confirmed,scheduled,in_progress,completed,cancelled"/>
                    </header>
                    <sheet>
                        <group>
                            <field name="name" readonly="1"/>
                            <field name="quote_number"/>
                            <field name="quote_date"/>
                            <field name="customer_id"/>
                            <field name="currency_id"/>
                            <field name="total_amount"/>
                        </group>

                        <notebook>
                            <page string="Line Items">
                                <field name="quote_line_ids">
                                    <form string="Quote Lines">
                                        <field name="product_id"/>
                                        <field name="quantity"/>
                                        <field name="unit_price"/>
                                        <field name="discount_pct"/>
                                        <field name="price_subtotal"/>
                                    </form>
                                </field>
                            </page>

                            <page string="Metrics">
                                <group>
                                    <field name="total_quote_amount" readonly="1"/>
                                    <field name="total_cost" readonly="1"/>
                                    <field name="product_count" readonly="1"/>
                                    <field name="quote_line_count" readonly="1"/>
                                </group>
                            </page>

                            <page string="Notes">
                                <field name="description" widget="html"/>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- Menu Item for Solar Quotes -->
        <menuitem id="menu_solar_quotes" name="Solar Quotes"
                  parent="base.menu_sales" action="action_solar_quote"/>
    </data>
</odoo>
