<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Define Solar Category -->
        <record id="module_category_solar" model="ir.module.category">
            <field name="name">Solar Installation</field>
            <field name="description">Manage solar installation projects</field>
            <field name="sequence">20</field>
        </record>

        <!-- Solar User Group -->
        <record id="group_solar_user" model="res.groups">
            <field name="name">User</field>
            <field name="category_id" ref="module_category_solar"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <!-- Solar Manager Group -->
        <record id="group_solar_manager" model="res.groups">
            <field name="name">Manager</field>
            <field name="category_id" ref="module_category_solar"/>
            <field name="implied_ids" eval="[(4, ref('group_solar_user'))]"/>
            <field name="users" eval="[(4, ref('base.user_admin'))]"/>
        </record>

        <!-- Multi-Company Rules -->
        <record id="solar_project_company_rule" model="ir.rule">
            <field name="name">Solar Project: Multi-Company</field>
            <field name="model_id" ref="model_solar_project"/>
            <field name="global" eval="True"/>
            <field name="domain_force">['|', ('company_id', '=', False), ('company_id', 'in', company_ids)]</field>
        </record>

        <record id="solar_quote_company_rule" model="ir.rule">
            <field name="name">Solar Quote: Multi-Company</field>
            <field name="model_id" ref="model_solar_quote"/>
            <field name="global" eval="True"/>
            <field name="domain_force">[(1, '=', 1)]</field>
        </record>

        <record id="solar_product_company_rule" model="ir.rule">
            <field name="name">Solar Product: Multi-Company</field>
            <field name="model_id" ref="model_solar_product_product"/>
            <field name="global" eval="True"/>
            <field name="domain_force">[(1, '=', 1)]</field>
        </record>

        <!-- Record Rules -->
        <record id="solar_project_user_rule" model="ir.rule">
            <field name="name">Solar Project: User Access</field>
            <field name="model_id" ref="model_solar_project"/>
            <field name="domain_force">[('state', 'not in', ['cancelled'])]</field>
            <field name="groups" eval="[(4, ref('group_solar_user'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <record id="solar_project_manager_rule" model="ir.rule">
            <field name="name">Solar Project: Manager Access</field>
            <field name="model_id" ref="model_solar_project"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_solar_manager'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>

        <!-- Quote Rules -->
        <record id="solar_quote_user_rule" model="ir.rule">
            <field name="name">Solar Quote: User Access</field>
            <field name="model_id" ref="model_solar_quote"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_solar_user'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <record id="solar_quote_manager_rule" model="ir.rule">
            <field name="name">Solar Quote: Manager Access</field>
            <field name="model_id" ref="model_solar_quote"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_solar_manager'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>

        <!-- Survey Rules -->
        <record id="solar_survey_user_rule" model="ir.rule">
            <field name="name">Solar Survey: User Access</field>
            <field name="model_id" ref="model_solar_site_survey"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_solar_user'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <!-- Schedule Rules -->
        <record id="solar_schedule_user_rule" model="ir.rule">
            <field name="name">Solar Schedule: User Access</field>
            <field name="model_id" ref="model_solar_install_schedule"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_solar_user'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <!-- Team Rules -->
        <record id="solar_team_user_rule" model="ir.rule">
            <field name="name">Solar Team: User Access</field>
            <field name="model_id" ref="model_solar_install_team"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_solar_user'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <!-- Product Rules -->
        <record id="solar_product_user_rule" model="ir.rule">
            <field name="name">Solar Product: User Access</field>
            <field name="model_id" ref="model_solar_product_product"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_solar_user'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <!-- Skill Rules -->
        <record id="solar_skill_user_rule" model="ir.rule">
            <field name="name">Solar Skill: User Access</field>
            <field name="model_id" ref="model_solar_install_skill"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_solar_user'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="False"/>
        </record>
    </data>
</odoo>