<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- Architect Team Views -->
        <record id="view_architect_team_tree" model="ir.ui.view">
            <field name="name">architect.team.tree</field>
            <field name="model">architect.team</field>
            <field name="arch" type="xml">
                <tree>
                    <field name="name"/>
                    <field name="project_id"/>
                    <field name="team_lead_id"/>
                    <field name="member_count"/>
                    <field name="active"/>
                </tree>
            </field>
        </record>

        <record id="view_architect_team_form" model="ir.ui.view">
            <field name="name">architect.team.form</field>
            <field name="model">architect.team</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <group>
                                <field name="name"/>
                                <field name="project_id"/>
                                <field name="team_lead_id"/>
                            </group>
                            <group>
                                <field name="active"/>
                                <field name="member_count"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="Team Members">
                                <field name="member_ids">
                                    <tree editable="bottom">
                                        <field name="user_id"/>
                                        <field name="role"/>
                                        <field name="join_date"/>
                                        <field name="active"/>
                                    </tree>
                                </field>
                            </page>
                            <page string="Description">
                                <field name="description"/>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- Actions -->
        <record id="action_architect_team" model="ir.actions.act_window">
            <field name="name">Teams</field>
            <field name="res_model">architect.team</field>
            <field name="view_mode">tree,form</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Create your first team!
                </p>
                <p>
                    Organize your architect teams by projects and manage team members efficiently.
                </p>
            </field>
        </record>

        <!-- Team Collaboration Views -->
        <record id="view_team_collaboration_tree" model="ir.ui.view">
            <field name="name">architect.team.collaboration.tree</field>
            <field name="model">architect.team.collaboration</field>
            <field name="arch" type="xml">
                <tree>
                    <field name="name"/>
                    <field name="collaboration_type"/>
                    <field name="project_id"/>
                    <field name="team_id"/>
                    <field name="scheduled_date"/>
                    <field name="state"/>
                </tree>
            </field>
        </record>

        <record id="view_team_collaboration_form" model="ir.ui.view">
            <field name="name">architect.team.collaboration.form</field>
            <field name="model">architect.team.collaboration</field>
            <field name="arch" type="xml">
                <form>
                    <header>
                        <field name="state" widget="statusbar"/>
                    </header>
                    <sheet>
                        <group>
                            <group>
                                <field name="name"/>
                                <field name="collaboration_type"/>
                                <field name="project_id"/>
                                <field name="team_id"/>
                            </group>
                            <group>
                                <field name="scheduled_date"/>
                                <field name="duration"/>
                                <field name="location"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="Participants">
                                <field name="participant_ids"/>
                            </page>
                            <page string="Agenda">
                                <field name="agenda"/>
                            </page>
                            <page string="Minutes">
                                <field name="minutes"/>
                            </page>
                            <page string="Action Items">
                                <field name="action_items"/>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>
    
        <record id="action_architect_team_member" model="ir.actions.act_window">
            <field name="name">Team Members</field>
            <field name="res_model">architect.team.member</field>
            <field name="view_mode">tree,form</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Add your first team member
                </p>
                <p>
                    Manage team member profiles, skills, and certifications.
                </p>
            </field>
        </record>
    
        <record id="action_architect_skill" model="ir.actions.act_window">
            <field name="name">Skills</field>
            <field name="res_model">architect.skill</field>
            <field name="view_mode">tree,form</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Define your first skill
                </p>
                <p>
                    Create a catalog of professional skills for team members.
                </p>
            </field>
        </record>
    
        <!-- Menu Items -->
        <menuitem id="menu_team_root" name="Teams" 
                  parent="menu_architect_root" sequence="50"/>
        
        <menuitem id="menu_team" name="Teams" 
                  parent="menu_team_root" 
                  action="action_architect_team" sequence="10"/>
        
        <menuitem id="menu_team_member" name="Team Members" 
                  parent="menu_team_root" 
                  action="action_architect_team_member" sequence="20"/>
        
        <menuitem id="menu_skill" name="Skills" 
                  parent="menu_team_root" 
                  action="action_architect_skill" sequence="30"/>
    </data>
</odoo>