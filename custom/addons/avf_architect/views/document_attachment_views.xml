<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_architect_document_attachment_form" model="ir.ui.view">
        <field name="name">architect.document.attachment.form</field>
        <field name="model">architect.document.attachment</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="file" filename="file_name"/>
                        <field name="file_name" invisible="1"/>
                        <field name="file_size" readonly="1"/>
                        <field name="file_type" readonly="1"/>
                        <field name="mime_type" readonly="1"/>
                        <field name="checksum" readonly="1" groups="base.group_no_one"/>
                        <field name="description"/>
                        <field name="res_model" invisible="1"/>
                        <field name="res_id" invisible="1"/>
                    </group>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids" widget="mail_followers"/>
                    <field name="activity_ids" widget="mail_activity"/>
                    <field name="message_ids" widget="mail_thread"/>
                </div>
            </form>
        </field>
    </record>

    <record id="view_architect_document_attachment_tree" model="ir.ui.view">
        <field name="name">architect.document.attachment.tree</field>
        <field name="model">architect.document.attachment</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="file_name"/>
                <field name="file_size"/>
                <field name="file_type"/>
                <field name="create_date"/>
                <field name="create_uid"/>
            </tree>
        </field>
    </record>
</odoo>
