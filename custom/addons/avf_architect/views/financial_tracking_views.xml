
<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Financial Tracking Form View -->
    <record id="view_architect_financial_tracking_form" model="ir.ui.view">
        <field name="name">architect.financial.tracking.form</field>
        <field name="model">architect.financial.tracking</field>
        <field name="arch" type="xml">
            <form string="Financial Tracking">
                <header>
                    <button name="action_confirm" string="Confirm" type="object" 
                            class="oe_highlight" attrs="{'invisible': [('state', '!=', 'draft')]}"/>
                    <button name="action_mark_paid" string="Mark as Paid" type="object" 
                            class="btn-success" attrs="{'invisible': [('state', '!=', 'confirmed')]}"/>
                    <button name="action_cancel" string="Cancel" type="object" 
                            class="btn-secondary" attrs="{'invisible': [('state', 'in', ['paid', 'cancelled'])]}"/>
                    <field name="state" widget="statusbar" 
                           statusbar_visible="draft,confirmed,paid"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Transaction Reference"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="project_id"/>
                            <field name="transaction_type"/>
                            <field name="category_id"/>
                            <field name="amount" widget="monetary"/>
                            <field name="currency_id" invisible="1"/>
                        </group>
                        <group>
                            <field name="date"/>
                            <field name="due_date"/>
                            <field name="approved_by"/>
                            <field name="approval_date"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Details" name="details">
                            <group>
                                <field name="description" placeholder="Transaction description..."/>
                                <field name="notes" placeholder="Additional notes..."/>
                            </group>
                        </page>
                        <page string="Related Records" name="related">
                            <group>
                                <field name="invoice_id"/>
                                <field name="payment_id"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- Financial Tracking Kanban View -->
    <record id="view_architect_financial_tracking_kanban" model="ir.ui.view">
        <field name="name">architect.financial.tracking.kanban</field>
        <field name="model">architect.financial.tracking</field>
        <field name="arch" type="xml">
            <kanban default_group_by="state" class="o_kanban_small_column">
                <field name="state"/>
                <field name="transaction_type"/>
                <field name="amount"/>
                <field name="currency_id"/>
                <field name="date"/>
                <field name="project_id"/>
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_card oe_kanban_global_click">
                            <div class="oe_kanban_content">
                                <div class="o_kanban_record_title">
                                    <field name="name"/>
                                </div>
                                <div class="o_kanban_record_subtitle">
                                    <field name="project_id"/>
                                </div>
                                <div class="o_kanban_record_bottom">
                                    <div class="oe_kanban_bottom_left">
                                        <span class="badge" t-attf-class="badge-#{record.transaction_type.raw_value == 'income' ? 'success' : record.transaction_type.raw_value == 'expense' ? 'danger' : 'info'}">
                                            <field name="transaction_type"/>
                                        </span>
                                    </div>
                                    <div class="oe_kanban_bottom_right">
                                        <field name="amount" widget="monetary"/>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- Financial Tracking Calendar View -->
    <record id="view_architect_financial_tracking_calendar" model="ir.ui.view">
        <field name="name">architect.financial.tracking.calendar</field>
        <field name="model">architect.financial.tracking</field>
        <field name="arch" type="xml">
            <calendar string="Financial Calendar" date_start="date" color="transaction_type">
                <field name="name"/>
                <field name="amount"/>
                <field name="project_id"/>
                <field name="transaction_type"/>
            </calendar>
        </field>
    </record>

    <!-- Financial Tracking List View (minimal) -->
    <record id="view_architect_financial_tracking_list" model="ir.ui.view">
        <field name="name">architect.financial.tracking.list</field>
        <field name="model">architect.financial.tracking</field>
        <field name="arch" type="xml">
            <list string="Financial Tracking">
                <field name="name"/>
                <field name="project_id"/>
                <field name="transaction_type"/>
                <field name="amount" widget="monetary" sum="Total"/>
                <field name="currency_id" invisible="1"/>
                <field name="date"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <!-- Financial Tracking Search View -->
    <record id="view_architect_financial_tracking_search" model="ir.ui.view">
        <field name="name">architect.financial.tracking.search</field>
        <field name="model">architect.financial.tracking</field>
        <field name="arch" type="xml">
            <search string="Search Financial Records">
                <field name="name"/>
                <field name="project_id"/>
                <field name="category_id"/>
                <filter string="Income" name="income" 
                        domain="[('transaction_type', '=', 'income')]"/>
                <filter string="Expenses" name="expenses" 
                        domain="[('transaction_type', '=', 'expense')]"/>
                <filter string="This Month" name="this_month" 
                        domain="[('date', '>=', (context_today() - relativedelta(day=1)).strftime('%Y-%m-%d')),
                                ('date', '&lt;', (context_today() + relativedelta(months=1, day=1)).strftime('%Y-%m-%d'))]"/>
                <separator/>
                <filter string="Draft" name="draft" domain="[('state', '=', 'draft')]"/>
                <filter string="Confirmed" name="confirmed" domain="[('state', '=', 'confirmed')]"/>
                <filter string="Paid" name="paid" domain="[('state', '=', 'paid')]"/>
                <group expand="0" string="Group By">
                    <filter string="Project" name="group_project" context="{'group_by': 'project_id'}"/>
                    <filter string="Transaction Type" name="group_type" context="{'group_by': 'transaction_type'}"/>
                    <filter string="Status" name="group_state" context="{'group_by': 'state'}"/>
                    <filter string="Date" name="group_date" context="{'group_by': 'date'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Budget Kanban View -->
    <record id="view_architect_budget_kanban" model="ir.ui.view">
        <field name="name">architect.budget.kanban</field>
        <field name="model">architect.budget</field>
        <field name="arch" type="xml">
            <kanban default_group_by="state" class="o_kanban_small_column">
                <field name="state"/>
                <field name="total_budget"/>
                <field name="spent_amount"/>
                <field name="budget_utilization"/>
                <field name="currency_id"/>
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_card oe_kanban_global_click">
                            <div class="oe_kanban_content">
                                <div class="o_kanban_record_title">
                                    <field name="name"/>
                                </div>
                                <div class="o_kanban_record_subtitle">
                                    <field name="project_id"/>
                                </div>
                                <div class="o_kanban_tags_section">
                                    <div class="progress" style="height: 20px;">
                                        <div class="progress-bar" t-attf-style="width: #{record.budget_utilization.raw_value}%"
                                             t-attf-class="progress-bar-#{record.budget_utilization.raw_value &gt; 100 ? 'danger' : record.budget_utilization.raw_value &gt; 80 ? 'warning' : 'success'}">
                                            <t t-esc="Math.round(record.budget_utilization.raw_value)"/>%
                                        </div>
                                    </div>
                                </div>
                                <div class="o_kanban_record_bottom">
                                    <div class="oe_kanban_bottom_left">
                                        <span>Total: <field name="total_budget" widget="monetary"/></span>
                                    </div>
                                    <div class="oe_kanban_bottom_right">
                                        <span>Spent: <field name="spent_amount" widget="monetary"/></span>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- Budget Form View -->
    <record id="view_architect_budget_form" model="ir.ui.view">
        <field name="name">architect.budget.form</field>
        <field name="model">architect.budget</field>
        <field name="arch" type="xml">
            <form string="Project Budget">
                <header>
                    <button name="action_approve" string="Approve" type="object" 
                            class="oe_highlight" attrs="{'invisible': [('state', '!=', 'draft')]}"/>
                    <button name="action_activate" string="Activate" type="object" 
                            class="oe_highlight" attrs="{'invisible': [('state', '!=', 'approved')]}"/>
                    <button name="action_close" string="Close" type="object" 
                            class="btn-secondary" attrs="{'invisible': [('state', '!=', 'active')]}"/>
                    <field name="state" widget="statusbar" 
                           statusbar_visible="draft,approved,active,closed"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button type="object" class="oe_stat_button" icon="fa-bar-chart">
                            <div class="o_field_widget o_stat_info">
                                <span class="o_stat_value">
                                    <field name="budget_utilization" widget="percentage"/>
                                </span>
                                <span class="o_stat_text">Utilized</span>
                            </div>
                        </button>
                        <button type="object" class="oe_stat_button" icon="fa-money">
                            <div class="o_field_widget o_stat_info">
                                <span class="o_stat_value">
                                    <field name="remaining_budget" widget="monetary"/>
                                </span>
                                <span class="o_stat_text">Remaining</span>
                            </div>
                        </button>
                    </div>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Budget Name"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="project_id"/>
                            <field name="total_budget" widget="monetary"/>
                            <field name="currency_id" invisible="1"/>
                        </group>
                        <group>
                            <field name="start_date"/>
                            <field name="end_date"/>
                            <field name="approved_by"/>
                            <field name="approval_date"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Budget Lines" name="budget_lines">
                            <field name="budget_line_ids">
                                <list editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="name"/>
                                    <field name="category_id"/>
                                    <field name="allocated_amount" widget="monetary" sum="Total"/>
                                    <field name="spent_amount" widget="monetary" sum="Spent"/>
                                    <field name="remaining_amount" widget="monetary" sum="Remaining"/>
                                    <field name="utilization_percentage" widget="percentage"/>
                                </list>
                            </field>
                        </page>
                        <page string="Analysis" name="analysis">
                            <group>
                                <group>
                                    <field name="allocated_budget" widget="monetary" readonly="1"/>
                                    <field name="spent_amount" widget="monetary" readonly="1"/>
                                    <field name="remaining_budget" widget="monetary" readonly="1"/>
                                </group>
                                <group>
                                    <field name="budget_utilization" widget="percentage" readonly="1"/>
                                    <field name="variance_amount" widget="monetary" readonly="1"/>
                                    <field name="variance_percentage" widget="percentage" readonly="1"/>
                                </group>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- Cost Estimate Kanban View -->
    <record id="view_architect_cost_estimate_kanban" model="ir.ui.view">
        <field name="name">architect.cost.estimate.kanban</field>
        <field name="model">architect.cost.estimate</field>
        <field name="arch" type="xml">
            <kanban default_group_by="state" class="o_kanban_small_column">
                <field name="state"/>
                <field name="total_estimate"/>
                <field name="currency_id"/>
                <field name="estimate_date"/>
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_card oe_kanban_global_click">
                            <div class="oe_kanban_content">
                                <div class="o_kanban_record_title">
                                    <field name="name"/>
                                </div>
                                <div class="o_kanban_record_subtitle">
                                    <field name="project_id"/>
                                </div>
                                <div class="o_kanban_record_bottom">
                                    <div class="oe_kanban_bottom_left">
                                        <field name="estimate_date"/>
                                    </div>
                                    <div class="oe_kanban_bottom_right">
                                        <field name="total_estimate" widget="monetary"/>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- Cost Estimate Form View -->
    <record id="view_architect_cost_estimate_form" model="ir.ui.view">
        <field name="name">architect.cost.estimate.form</field>
        <field name="model">architect.cost.estimate</field>
        <field name="arch" type="xml">
            <form string="Cost Estimate">
                <header>
                    <button name="action_submit" string="Submit" type="object" 
                            class="oe_highlight" attrs="{'invisible': [('state', '!=', 'draft')]}"/>
                    <button name="action_approve" string="Approve" type="object" 
                            class="oe_highlight" attrs="{'invisible': [('state', '!=', 'submitted')]}"/>
                    <button name="action_reject" string="Reject" type="object" 
                            class="btn-warning" attrs="{'invisible': [('state', '!=', 'submitted')]}"/>
                    <field name="state" widget="statusbar" 
                           statusbar_visible="draft,submitted,approved"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Estimate Name"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="project_id"/>
                            <field name="version"/>
                            <field name="currency_id" invisible="1"/>
                        </group>
                        <group>
                            <field name="estimate_date"/>
                            <field name="validity_date"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Estimate Lines" name="estimate_lines">
                            <field name="estimate_line_ids">
                                <list editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="name"/>
                                    <field name="category_id"/>
                                    <field name="quantity"/>
                                    <field name="unit"/>
                                    <field name="unit_rate" widget="monetary"/>
                                    <field name="total_amount" widget="monetary" sum="Subtotal"/>
                                </list>
                            </field>
                        </page>
                        <page string="Summary" name="summary">
                            <group>
                                <group>
                                    <field name="contingency_percentage"/>
                                    <field name="contingency_amount" widget="monetary" readonly="1"/>
                                    <field name="overhead_percentage"/>
                                    <field name="overhead_amount" widget="monetary" readonly="1"/>
                                </group>
                                <group>
                                    <field name="profit_percentage"/>
                                    <field name="profit_amount" widget="monetary" readonly="1"/>
                                    <field name="total_estimate" widget="monetary" readonly="1" class="oe_subtotal_footer_separator"/>
                                </group>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- Menu Actions -->
    <record id="action_architect_financial_tracking" model="ir.actions.act_window">
        <field name="name">Financial Tracking</field>
        <field name="res_model">architect.financial.tracking</field>
        <field name="view_mode">kanban,form,list,calendar</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Record your first financial transaction
            </p>
            <p>
                Track all project income and expenses efficiently.
            </p>
        </field>
    </record>

    <record id="action_architect_budget" model="ir.actions.act_window">
        <field name="name">Project Budgets</field>
        <field name="res_model">architect.budget</field>
        <field name="view_mode">kanban,form,list</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first project budget
            </p>
            <p>
                Plan and monitor project budgets effectively.
            </p>
        </field>
    </record>

    <record id="action_architect_cost_estimate" model="ir.actions.act_window">
        <field name="name">Cost Estimates</field>
        <field name="res_model">architect.cost.estimate</field>
        <field name="view_mode">kanban,form,list</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first cost estimate
            </p>
            <p>
                Estimate project costs with confidence levels.
            </p>
        </field>
    </record>

    <!-- Financial Categories Action -->
    <record id="action_architect_financial_category" model="ir.actions.act_window">
        <field name="name">Financial Categories</field>
        <field name="res_model">architect.financial.category</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first financial category
            </p>
            <p>
                Organize financial transactions with categories.
            </p>
        </field>
    </record>

    <!-- Menu Items -->
    <menuitem id="menu_financial_root" name="Financial" 
              parent="menu_architect_root" sequence="20"/>
    
    <menuitem id="menu_financial_tracking" name="Financial Tracking" 
              parent="menu_financial_root" 
              action="action_architect_financial_tracking" sequence="10"/>
    
    <menuitem id="menu_budget" name="Budgets" 
              parent="menu_financial_root" 
              action="action_architect_budget" sequence="20"/>
    
    <menuitem id="menu_cost_estimate" name="Cost Estimates" 
              parent="menu_financial_root" 
              action="action_architect_cost_estimate" sequence="30"/>
    
    <menuitem id="menu_financial_category" name="Categories" 
              parent="menu_financial_root" 
              action="action_architect_financial_category" sequence="40"/>
</odoo>
