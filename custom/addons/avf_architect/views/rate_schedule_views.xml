
<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Rate Schedule Views (Placeholder) -->
        <record id="view_rate_schedule_tree" model="ir.ui.view">
            <field name="name">rate.schedule.tree</field>
            <field name="model">project.project</field>
            <field name="arch" type="xml">
                <tree string="Rate Schedule">
                    <field name="name"/>
                    <field name="partner_id"/>
                    <field name="date_start"/>
                    <field name="stage_id"/>
                </tree>
            </field>
        </record>

        <!-- Action -->
        <record id="action_rate_schedule" model="ir.actions.act_window">
            <field name="name">Rate Schedule</field>
            <field name="res_model">project.project</field>
            <field name="view_mode">tree,form</field>
            <field name="domain">[('is_architect_project', '=', True)]</field>
        </record>

    </data>
</odoo>
<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Rate Schedule Views -->
        <record id="view_architect_rate_schedule_tree" model="ir.ui.view">
            <field name="name">architect.rate.schedule.tree</field>
            <field name="model">architect.rate.schedule</field>
            <field name="arch" type="xml">
                <tree string="Rate Schedules">
                    <field name="name"/>
                    <field name="schedule_type"/>
                    <field name="state"/>
                    <field name="effective_date"/>
                    <field name="version"/>
                </tree>
            </field>
        </record>

        <record id="view_architect_rate_schedule_form" model="ir.ui.view">
            <field name="name">architect.rate.schedule.form</field>
            <field name="model">architect.rate.schedule</field>
            <field name="arch" type="xml">
                <form string="Rate Schedule">
                    <header>
                        <button name="action_activate" string="Activate" type="object" class="btn-primary"/>
                        <field name="state" widget="statusbar"/>
                    </header>
                    <sheet>
                        <group>
                            <group>
                                <field name="name"/>
                                <field name="schedule_type"/>
                                <field name="version"/>
                            </group>
                            <group>
                                <field name="effective_date"/>
                                <field name="state"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="Description">
                                <field name="description"/>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>
    </data>
</odoo>
</process>
<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Rate Schedule Views -->
    <record id="view_rate_schedule_tree" model="ir.ui.view">
        <field name="name">avf.rate.schedule.tree</field>
        <field name="model">avf.rate.schedule</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="schedule_type"/>
                <field name="state"/>
                <field name="rate"/>
                <field name="effective_date"/>
            </tree>
        </field>
    </record>

    <record id="view_rate_schedule_form" model="ir.ui.view">
        <field name="name">avf.rate.schedule.form</field>
        <field name="model">avf.rate.schedule</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="schedule_type"/>
                        <field name="state"/>
                        <field name="rate"/>
                        <field name="effective_date"/>
                    </group>
                    <group string="Details">
                        <field name="description" colspan="2"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_rate_schedule" model="ir.actions.act_window">
        <field name="name">Rate Schedule</field>
        <field name="res_model">avf.rate.schedule</field>
        <field name="view_mode">tree,form</field>
    </record>
</odoo>
