<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">
        <!-- Create stages with specific IDs to prevent FK constraint violations -->

        <!-- First, ensure the sequence exists -->
        <record id="seq_avf_project_stage" model="ir.sequence">
            <field name="name">AVF Project Stage Sequence</field>
            <field name="code">avf.project.stage</field>
            <field name="prefix">STAGE</field>
            <field name="padding">3</field>
            <field name="number_next">7</field>
        </record>

        <!-- Create stages with specific IDs that might be referenced -->
        <record id="stage_initiation" model="avf.project.stage">
            <field name="name">Initiation</field>
            <field name="sequence">1</field>
            <field name="description">Project initiation and setup</field>
            <field name="stage_type">initiation</field>
            <field name="active" eval="True"/>
            <field name="color">1</field>
            <field name="fold" eval="False"/>
        </record>

        <record id="stage_planning" model="avf.project.stage">
            <field name="name">Planning</field>
            <field name="sequence">2</field>
            <field name="description">Initial planning and design phase</field>
            <field name="stage_type">planning</field>
            <field name="active" eval="True"/>
            <field name="color">2</field>
            <field name="fold" eval="False"/>
        </record>

        <record id="stage_design" model="avf.project.stage">
            <field name="name">Design</field>
            <field name="sequence">3</field>
            <field name="description">Design development phase</field>
            <field name="stage_type">development</field>
            <field name="active" eval="True"/>
            <field name="color">3</field>
            <field name="fold" eval="False"/>
        </record>

        <record id="stage_approval" model="avf.project.stage">
            <field name="name">Approval</field>
            <field name="sequence">4</field>
            <field name="description">Approval and documentation phase</field>
            <field name="stage_type">monitoring</field>
            <field name="active" eval="True"/>
            <field name="color">4</field>
            <field name="fold" eval="False"/>
        </record>

        <record id="stage_execution" model="avf.project.stage">
            <field name="name">Execution</field>
            <field name="sequence">5</field>
            <field name="description">Project execution phase</field>
            <field name="stage_type">execution</field>
            <field name="active" eval="True"/>
            <field name="color">5</field>
            <field name="fold" eval="False"/>
        </record>

        <record id="stage_completion" model="avf.project.stage">
            <field name="name">Completion</field>
            <field name="sequence">6</field>
            <field name="description">Project completion and handover</field>
            <field name="stage_type">closure</field>
            <field name="active" eval="True"/>
            <field name="color">6</field>
            <field name="fold" eval="False"/>
        </record>

        <!-- Create additional stages that might be referenced by existing data -->
        <record id="stage_default" model="avf.project.stage">
            <field name="name">Default</field>
            <field name="sequence">0</field>
            <field name="description">Default stage for migration</field>
            <field name="stage_type">initiation</field>
            <field name="active" eval="True"/>
            <field name="color">0</field>
            <field name="fold" eval="False"/>
        </record>

    </data>
</odoo>