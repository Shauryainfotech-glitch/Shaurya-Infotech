<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <record id="seq_architect_project" model="ir.sequence">
            <field name="name">Architect Project Sequence</field>
            <field name="code">architect.project</field>
            <field name="prefix">ARCH-</field>
            <field name="padding">3</field>
            <field name="number_next">1</field>
            <field name="number_increment">1</field>
        </record>

        <!-- Drawing Management Sequences -->
        <record id="sequence_drawing_management" model="ir.sequence">
            <field name="name">Drawing Management Sequence</field>
            <field name="code">avf.drawing.management</field>
            <field name="prefix">DRW</field>
            <field name="padding">4</field>
            <field name="number_increment">1</field>
            <field name="number_next">1</field>
        </record>

        <!-- DPR Management Sequences -->
        <record id="sequence_dpr_management" model="ir.sequence">
            <field name="name">DPR Management Sequence</field>
            <field name="code">avf.dpr.management</field>
            <field name="prefix">DPR</field>
            <field name="padding">4</field>
            <field name="number_increment">1</field>
            <field name="number_next">1</field>
        </record>

        <record id="sequence_dpr_management_number" model="ir.sequence">
            <field name="name">DPR Number Sequence</field>
            <field name="code">avf.dpr.management.number</field>
            <field name="prefix">DPR</field>
            <field name="padding">3</field>
            <field name="number_increment">1</field>
            <field name="number_next">1</field>
        </record>

        <!-- Survey Management Sequences -->
        <record id="sequence_survey_management" model="ir.sequence">
            <field name="name">Survey Management Sequence</field>
            <field name="code">avf.survey.management</field>
            <field name="prefix">SUR</field>
            <field name="padding">4</field>
            <field name="number_increment">1</field>
            <field name="number_next">1</field>
        </record>

    </data>
</odoo>