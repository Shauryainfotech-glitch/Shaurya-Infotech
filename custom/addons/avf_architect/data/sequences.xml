<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- Project Code Sequence -->
        <record id="seq_avf_architect_project" model="ir.sequence">
            <field name="name">AVF Architect Project</field>
            <field name="code">avf.architect.project</field>
            <field name="prefix">ARCH-</field>
            <field name="padding">3</field>
            <field name="number_next">1</field>
            <field name="number_increment">1</field>
        </record>

        <!-- Survey Management Sequence -->
        <record id="seq_avf_survey_management" model="ir.sequence">
            <field name="name">Survey Management</field>
            <field name="code">avf.survey.management</field>
            <field name="prefix">SUR-</field>
            <field name="padding">3</field>
            <field name="number_next">1</field>
            <field name="number_increment">1</field>
        </record>

        <!-- Survey Number Sequence -->
        <record id="seq_avf_survey_number" model="ir.sequence">
            <field name="name">Survey Number</field>
            <field name="code">avf.survey.number</field>
            <field name="prefix">SN-</field>
            <field name="padding">4</field>
            <field name="number_next">1</field>
            <field name="number_increment">1</field>
        </record>

        <!-- DPR Management Sequence -->
        <record id="seq_avf_dpr_management" model="ir.sequence">
            <field name="name">DPR Management</field>
            <field name="code">avf.dpr.management</field>
            <field name="prefix">DPR-</field>
            <field name="padding">3</field>
            <field name="number_next">1</field>
            <field name="number_increment">1</field>
        </record>

        <!-- Drawing Number Sequence -->
        <record id="seq_avf_drawing_number" model="ir.sequence">
            <field name="name">Drawing Number</field>
            <field name="code">avf.drawing.number</field>
            <field name="prefix">DRW-</field>
            <field name="padding">4</field>
            <field name="number_next">1</field>
            <field name="number_increment">1</field>
        </record>

        <!-- Compliance Tracking Sequence -->
        <record id="seq_avf_compliance_tracking" model="ir.sequence">
            <field name="name">Compliance Tracking</field>
            <field name="code">avf.compliance.tracking</field>
            <field name="prefix">COMP-</field>
            <field name="padding">4</field>
            <field name="number_next">1</field>
            <field name="number_increment">1</field>
        </record>

        <!-- Document Management Sequence -->
        <record id="seq_avf_document_management" model="ir.sequence">
            <field name="name">Document Management</field>
            <field name="code">avf.document.management</field>
            <field name="prefix">DOC-</field>
            <field name="padding">4</field>
            <field name="number_next">1</field>
            <field name="number_increment">1</field>
        </record>

        <!-- Financial Tracking Sequence -->
        <record id="seq_avf_financial_tracking" model="ir.sequence">
            <field name="name">Financial Tracking</field>
            <field name="code">avf.financial.tracking</field>
            <field name="prefix">FIN-</field>
            <field name="padding">4</field>
            <field name="number_next">1</field>
            <field name="number_increment">1</field>
        </record>

        <!-- AI Assistant Sequence -->
        <record id="seq_avf_ai_assistant" model="ir.sequence">
            <field name="name">AI Assistant</field>
            <field name="code">avf.ai.assistant</field>
            <field name="prefix">AI-</field>
            <field name="padding">4</field>
            <field name="number_next">1</field>
            <field name="number_increment">1</field>
        </record>

            <!-- DPR Report Number Sequence -->
    <record id="seq_dpr_number" model="ir.sequence">
        <field name="name">DPR Number</field>
        <field name="code">avf.dpr.number</field>
        <field name="prefix">DPR-</field>
        <field name="padding">3</field>
        <field name="number_next">1</field>
        <field name="number_increment">1</field>
    </record>

    <!-- Default Project Stages -->
    <record id="stage_planning" model="avf.project.stage">
        <field name="name">Planning</field>
        <field name="sequence">1</field>
        <field name="description">Initial planning and design phase</field>
    </record>

    <record id="stage_design" model="avf.project.stage">
        <field name="name">Design</field>
        <field name="sequence">2</field>
        <field name="description">Design development phase</field>
    </record>

    <record id="stage_approval" model="avf.project.stage">
        <field name="name">Approval</field>
        <field name="sequence">3</field>
        <field name="description">Approval and documentation phase</field>
    </record>

    <record id="stage_execution" model="avf.project.stage">
        <field name="name">Execution</field>
        <field name="sequence">4</field>
        <field name="description">Project execution phase</field>
    </record>

    <record id="stage_completion" model="avf.project.stage">
        <field name="name">Completion</field>
        <field name="sequence">5</field>
        <field name="description">Project completion and handover</field>
    </record>

    </data>
</odoo>