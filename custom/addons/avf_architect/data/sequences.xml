
<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Sequences -->
        <record id="seq_dpr_management" model="ir.sequence">
            <field name="name">DPR Management</field>
            <field name="code">avf.dpr.management</field>
            <field name="prefix">DPR</field>
            <field name="padding">4</field>
            <field name="number_next">1</field>
            <field name="number_increment">1</field>
        </record>

        <record id="seq_drawing_management" model="ir.sequence">
            <field name="name">Drawing Management</field>
            <field name="code">avf.drawing.management</field>
            <field name="prefix">DRW</field>
            <field name="padding">4</field>
            <field name="number_next">1</field>
            <field name="number_increment">1</field>
        </record>
    </data>
</odoo>
