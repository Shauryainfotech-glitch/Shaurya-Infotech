
<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- AVF Architect Security Groups -->
        <record id="group_avf_architect_user" model="res.groups">
            <field name="name">AVF Architect User</field>
            <field name="category_id" ref="base.module_category_project"/>
            <field name="implied_ids" eval="[(4, ref('project.group_project_user'))]"/>
        </record>

        <record id="group_avf_architect_manager" model="res.groups">
            <field name="name">AVF Architect Manager</field>
            <field name="category_id" ref="base.module_category_project"/>
            <field name="implied_ids" eval="[(4, ref('group_avf_architect_user')), (4, ref('project.group_project_manager'))]"/>
        </record>

        <record id="group_avf_architect_admin" model="res.groups">
            <field name="name">AVF Architect Administrator</field>
            <field name="category_id" ref="base.module_category_project"/>
            <field name="implied_ids" eval="[(4, ref('group_avf_architect_manager'))]"/>
        </record>

        <!-- Record Rules -->
        <record id="avf_architect_project_rule" model="ir.rule">
            <field name="name">AVF Architect Project Access</field>
            <field name="model_id" ref="project.model_project_project"/>
            <field name="domain_force">['|', ('user_id', '=', user.id), ('user_id', '=', False)]</field>
            <field name="groups" eval="[(4, ref('group_avf_architect_user'))]"/>
        </record>
    </data>
</odoo>
